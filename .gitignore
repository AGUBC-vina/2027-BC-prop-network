.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.venv/
venv/

# Claude Code workspace state (preview server config, settings) — not part of
# the dashboard
.claude/

# Old / scratch workbooks kept locally
secondary/

# Cached raw downloads — re-fetchable via scripts/fetch_dwr_measurements.py,
# scripts/resolve_sites.py, and the B118 ArcGIS REST query documented in
# README.md. The full state-wide stations.csv (~8 MB) and bulk DWR downloads
# don't need to live in git.
raw/

# Intermediate data files emitted by the build scripts. The dashboard reads
# only the bundled `js/*-data.js` files, so we don't need the .json sources
# (they're re-generated by `python3 scripts/*.py`).
data/wells_resolved.json
data/measurements.json
